{
  "name": "video-toolkit-aio-pro",
  "productName": "Video Toolkit AIO Pro",
  "version": "1.0.0",
  "description": "Desktop app xử lý video đa năng (All-In-One) — FFmpeg + yt-dlp",
  "main": "./out/main/index.js",
  "author": "ANS Studio",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron-vite preview",
    "smoke": "electron-vite build && cross-env VT_SMOKE=1 electron .",
    "fetch-bins": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "dist": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
