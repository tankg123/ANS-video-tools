{
  "name": "ans-video-tools",
  "productName": "ANS Video Tools",
  "version": "1.3.0",
  "description": "Desktop app xử lý video đa năng (All-In-One) — FFmpeg + yt-dlp",
  "main": "./out/main/index.js",
  "author": "ANS Studio",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron-vite preview",
    "smoke": "electron-vite build && cross-env VT_SMOKE=1 electron .",
    "fetch-bins": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "dist": "electron-vite build && electron-builder --win --publish never",
    "release:patch": "npm version patch --no-git-tag-version && npm run dist",
    "release:minor": "npm version minor --no-git-tag-version && npm run dist",
    "release:major": "npm version major --no-git-tag-version && npm run dist"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "builder-util-runtime": "^9.7.0",
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
