{
  "name": "video-toolkit-aio-pro",
  "productName": "Video Toolkit AIO Pro",
  "version": "1.0.0",
  "description": "Desktop app xử lý video đa năng (All-In-One) — FFmpeg + yt-dlp",
  "main": "./out/main/index.js",
  "author": "ANS Studio",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
